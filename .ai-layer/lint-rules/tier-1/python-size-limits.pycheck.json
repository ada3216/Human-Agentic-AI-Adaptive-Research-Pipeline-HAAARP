{
  "rule": "required_matches",
  "required_paths": [
    "scripts/size-check.sh"
  ],
  "checks": [
    {
      "path": "Makefile",
      "regex": "bash scripts/size-check\\.sh"
    },
    {
      "path": "scripts/size-check.sh",
      "regex": "max_file_lines"
    },
    {
      "path": "scripts/size-check.sh",
      "regex": "max_function_lines"
    }
  ]
}
