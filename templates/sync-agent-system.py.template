#!/usr/bin/env python3
"""Synchronize generated agent-system artifacts with repo source-of-truth docs.

init.agent should substitute the repo-specific file list or commands when
instantiating this template in a target repository.
"""

from __future__ import annotations

from pathlib import Path
import sys

ROOT = Path(__file__).resolve().parent.parent
TRACKED_FILES = [
    ROOT / "REPO.context.md",
    ROOT / "docs" / "agent-system" / "repo-profile.md",
    ROOT / "docs" / "agent-system" / "validation-registry.md",
    ROOT / "docs" / "agent-system" / "workflow-registry.md",
    ROOT / "docs" / "agent-system" / "hook-registry.md",
]


def main() -> int:
    missing = [str(path.relative_to(ROOT)) for path in TRACKED_FILES if not path.exists()]
    if missing:
        print("sync-agent-system: missing required files:")
        for path in missing:
            print(f"- {path}")
        return 1

    print("sync-agent-system: all tracked files are present")
    print("sync-agent-system: replace this template logic with repo-specific sync rules if needed")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
