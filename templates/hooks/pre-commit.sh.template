#!/usr/bin/env bash
set -euo pipefail

# Generated from the framework template.
# init.agent should substitute the commands below when generating a repo file.

ROOT_DIR="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
cd "$ROOT_DIR"

LINT_CMD="${LINT_CMD:-__LINT_COMMAND__}"
TYPECHECK_CMD="${TYPECHECK_CMD:-__TYPECHECK_COMMAND__}"
TEST_CMD="${TEST_CMD:-__FAST_TEST_COMMAND__}"

run_if_configured() {
  local label="$1"
  local command="$2"

  if [[ -z "$command" || "$command" == __*__ ]]; then
    echo "[pre-commit] Skipping $label: no command configured"
    return 0
  fi

  echo "[pre-commit] Running $label"
  eval "$command"
}

run_if_configured "lint" "$LINT_CMD"
run_if_configured "type check" "$TYPECHECK_CMD"
run_if_configured "fast tests" "$TEST_CMD"

echo "[pre-commit] Completed successfully"
