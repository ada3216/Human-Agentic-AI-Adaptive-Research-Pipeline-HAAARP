{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    ".ai-layer/PROJECT_CONFIG.md"
  ],
  "default_agent": "mag-student",
  "plugin": [
    "./.opencode/plugins/gatekeeper.js"
  ],
  "permission": {
    "profile": "sensitive-project",
    "network": "deny-by-default",
    "secrets": "no-repo-storage",
    "data_egress": "explicit-approval-required"
  },
  "mcp": {
    "memory": {
      "type": "local",
      "command": [
        "node",
        "node_modules/@modelcontextprotocol/server-memory/dist/index.js"
      ],
      "environment": {}
    }
  }
}
